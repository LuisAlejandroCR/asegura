# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000

# ── Supabase (Sprint 0) ────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── LLM (Sprint 1) ─────────────────────────────────────────────────────────────
# Groq (recommended): LLM_API_KEY from https://console.groq.com/keys, LLM_MODEL=llama-3.1-8b-instant
# Ollama (local): LLM_BASE_URL=http://localhost:11434, LLM_MODEL=mistral
LLM_PROVIDER=groq
LLM_BASE_URL=
LLM_API_KEY=gsk_...
LLM_MODEL=llama-3.1-8b-instant

# ── Telegram (Sprint 1) ────────────────────────────────────────────────────────
# PUBLIC_URL: this app's public base URL (used to register the Telegram webhook).
# Leave unset for local polling mode — no TELEGRAM_WEBHOOK_SECRET needed then.
PUBLIC_URL=https://your-app.up.railway.app
TELEGRAM_BOT_TOKEN=1234567890:AAF...
TELEGRAM_WEBHOOK_SECRET=your-random-secret-32-chars

# ── Wompi (Sprint 5) ──────────────────────────────────────────────────────────
WOMPI_ENVIRONMENT=sandbox
WOMPI_PUBLIC_KEY=pub_test_...
WOMPI_PRIVATE_KEY=prv_test_...
WOMPI_EVENTS_SECRET=...
WOMPI_INTEGRITY_KEY=...

# ── Celo (Sprint 6) ───────────────────────────────────────────────────────────
CELO_RPC_URL=https://forno.celo.org
OPERATOR_PRIVATE_KEY=0x...
POLICY_LEDGER_ADDRESS=0x...

# ── App (Sprint 2+) ───────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars
ADMIN_CHAT_ID=your-telegram-chat-id
